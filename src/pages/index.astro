---
import { getCollection } from "astro:content";
import Link from "../components/Link.astro";
import Base from "../layouts/Base.astro";
import { displayTags } from "../lib/posts";

const PAGE_SIZE = 10;

const allPosts = (
  await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const posts = allPosts.slice(0, PAGE_SIZE);
---

<Base title="Posts">
  <h1>Posts</h1>
  <hr />
  <ul>
    {
      posts.map((post) => (
        <li>
          <time datetime={post.data.date.toISOString().slice(0, 10)}>
            {post.data.date.toISOString().slice(0, 10)}
          </time>
          <Link href={`/posts/${post.id}`}>{post.data.title}</Link>
          {displayTags(post).length > 0 && (
            <span class="tags">
              {displayTags(post).map((tag) => (
                <Link href={`/tags/${tag}`} class="tag">
                  {tag}
                </Link>
              ))}
            </span>
          )}
        </li>
      ))
    }
  </ul>
  {
    totalPages > 1 && (
      <div class="pagination">
        <span />
        <Link href="/2">Next</Link>
      </div>
    )
  }
</Base>
