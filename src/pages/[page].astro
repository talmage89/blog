---
import { getCollection } from "astro:content";
import Link from "../components/Link.astro";
import Base from "../layouts/Base.astro";

export async function getStaticPaths() {
  const pageSize = 10;
  const allPosts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  const totalPages = Math.ceil(allPosts.length / pageSize);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageSize = 10;
const allPosts = (
  await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(allPosts.length / pageSize);
const page = parseInt(Astro.params.page!, 10);
const start = (page - 1) * pageSize;
const posts = allPosts.slice(start, start + pageSize);
---

<Base title={`blog — page ${page}`}>
  <ul>
    {
      posts.map((post) => (
        <li>
          <time datetime={post.data.date.toISOString().slice(0, 10)}>
            {post.data.date.toISOString().slice(0, 10)}
          </time>
          <Link href={`/posts/${post.id}`}>
            {post.data.draft && "(draft) "}
            {post.data.title}
          </Link>
          {post.data.tags.length > 0 && (
            <span class="tags">
              {post.data.tags.map((tag: string) => (
                <Link href={`/tags/${tag}`} class="tag">
                  {tag}
                </Link>
              ))}
            </span>
          )}
        </li>
      ))
    }
  </ul>
  <div class="pagination">
    <Link href={page === 2 ? "/" : `/${page - 1}`}>&larr; prev</Link>
    {
      page < totalPages ? (
        <Link href={`/${page + 1}`}>next &rarr;</Link>
      ) : (
        <span />
      )
    }
  </div>
</Base>
