---
import { getCollection } from "astro:content";
import Link from "../components/Link.astro";
import Base from "../layouts/Base.astro";
import { displayTags } from "../lib/posts";

export async function getStaticPaths() {
  const pageSize = 10;
  const allPosts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  const totalPages = Math.ceil(allPosts.length / pageSize);
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageSize = 10;
const allPosts = (
  await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  })
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(allPosts.length / pageSize);
const page = parseInt(Astro.params.page!, 10);
const start = (page - 1) * pageSize;
const posts = allPosts.slice(start, start + pageSize);
---

<Base title={`Page ${page}`}>
  <h1>Posts</h1>
  <hr />
  <ul>
    {
      posts.map((post) => (
        <li>
          <time datetime={post.data.date.toISOString().slice(0, 10)}>
            {post.data.date.toISOString().slice(0, 10)}
          </time>
          <Link href={`/posts/${post.id}`}>{post.data.title}</Link>
          {displayTags(post).length > 0 && (
            <span class="tags">
              {displayTags(post).map((tag: string) => (
                <Link href={`/tags/${tag}`} class="tag">
                  {tag}
                </Link>
              ))}
            </span>
          )}
        </li>
      ))
    }
  </ul>
  <div class="pagination">
    <Link href={page === 2 ? "/" : `/${page - 1}`}>Prev</Link>
    {
      page < totalPages ? (
        <Link href={`/${page + 1}`}>Next</Link>
      ) : (
        <span />
      )
    }
  </div>
</Base>
